  <!-- Auto-copy DLL to BepInEx plugins after build -->
  <Target Name="CopyToPlugins" AfterTargets="PostBuildEvent" Condition="'$(Configuration)' == 'Debug'">
    <!-- Clean up old duplicate DLLs from BepInEx root plugins folders to prevent conflicts -->
    <Delete Files="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\ShipCommander.dll" TreatErrorsAsWarnings="true" />
    <Delete Files="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Default\BepInEx\plugins\ShipCommander.dll" TreatErrorsAsWarnings="true" />
    <RemoveDir Directories="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Default\BepInEx\plugins\ShipCommander\" ContinueOnError="true" />
    <RemoveDir Directories="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\ShipCommander\" ContinueOnError="true" />
    
    <!-- Test profile copy -->
    <MakeDir Directories="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\Unknown-ShipCommander\" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\Unknown-ShipCommander\" />
    <Copy SourceFiles="$(ProjectDir)\hammer-knock-on-metal.mp3" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\Unknown-ShipCommander\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(ProjectDir)\solid-confident-knock-with-a-hammer.mp3" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\Unknown-ShipCommander\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(ProjectDir)\neiz_esten-elektricheskiy-razryadz_uk.mp3" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\Unknown-ShipCommander\" SkipUnchangedFiles="true" />

    <!-- Default profile copy -->
    <MakeDir Directories="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Default\BepInEx\plugins\Unknown-ShipCommander\" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Default\BepInEx\plugins\Unknown-ShipCommander\" />
    <Copy SourceFiles="$(ProjectDir)\hammer-knock-on-metal.mp3" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Default\BepInEx\plugins\Unknown-ShipCommander\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(ProjectDir)\solid-confident-knock-with-a-hammer.mp3" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Default\BepInEx\plugins\Unknown-ShipCommander\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(ProjectDir)\neiz_esten-elektricheskiy-razryadz_uk.mp3" DestinationFolder="$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Default\BepInEx\plugins\Unknown-ShipCommander\" SkipUnchangedFiles="true" />

