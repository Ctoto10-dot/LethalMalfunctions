<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>LethalMalfunctions</AssemblyName>
    <RootNamespace>ShipCommander</RootNamespace>
    <Description>Enhanced ship navigator gameplay for Lethal Company</Description>
    <Version>1.1.0</Version>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <!-- Suppress warnings about targeting older framework -->
    <NoWarn>$(NoWarn);NU1701</NoWarn>
  </PropertyGroup>

  <!-- BepInEx core DLLs from local install -->
  <ItemGroup>
    <Reference Include="BepInEx">
      <HintPath>$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\core\BepInEx.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="BepInEx.Preloader">
      <HintPath>$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\core\BepInEx.Preloader.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\core\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="LethalNetworkAPI">
      <HintPath>$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\xilophor-LethalNetworkAPI\LethalNetworkAPI\LethalNetworkAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="TerminalApi">
      <HintPath>$(AppData)\r2modmanPlus-local\LethalCompany\profiles\Test\BepInEx\plugins\NotAtomicBomb-TerminalApi\TerminalApi.dll</HintPath>
